{
  "name": "leaf_classification",
  "strict": true,
  "schema": {
    "type": "object",
    "required": ["description", "common_brands", "typical_price_range"],
    "properties": {
      "description": {
        "type": "string",
        "description": "One sentence description of the item"
      },
      "common_brands": {
        "type": "array",
        "items": { "type": "string" },
        "description": "2-3 common brands"
      },
      "typical_price_range": {
        "type": "string",
        "description": "Typical price range like '$2-5'"
      }
    },
    "additionalProperties": false
  }
}
